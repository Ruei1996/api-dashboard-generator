# =============================================================
#  Repo Insight Dashboard — Environment Configuration
#  Copy this file to .env and fill in your values.
#
#  SETUP (run once after copying):
#    cp .env.example .env
#    chmod 600 .env        ← REQUIRED: restrict to owner read-only.
#                            Without this, all local users on the machine
#                            can read your Copilot token.
#
#  NEVER commit the .env file — it is already in .gitignore.
#  This file (.env.example) is safe to commit; it contains no secrets.
# =============================================================

# ── GitHub Copilot API Token ─────────────────────────────────
# Required to enable AI-powered semantic analysis:
#   • Project summary (繁體中文摘要)
#   • Design pattern detection (DDD / CQRS / Microservices …)
#   • Security risk identification
#   • Swagger field translation
#
# How to obtain:
#   1. Install the GitHub Copilot VS Code extension, or
#   2. Generate a token via GitHub CLI:
#      gh auth token   (requires `copilot` scope)
#
# This value can also be passed directly via:
#   rid analyze <path> --copilot-token <TOKEN>
# CLI flags always take precedence over this file.
# CI/CD: set this as a repository secret, not in a .env file.
GITHUB_COPILOT_TOKEN=

# ── Copilot AI Model ─────────────────────────────────────────
# The OpenAI-compatible model served by api.githubcopilot.com.
# Default: gpt-4o
# Accepted values (allowlisted in code):
#   gpt-4o        — recommended: best accuracy
#   gpt-4o-mini   — faster, lower cost, slightly less accurate
#   gpt-4.1       — latest snapshot (if your plan supports it)
# Unknown values are silently replaced with gpt-4o.
COPILOT_MODEL=gpt-4o
