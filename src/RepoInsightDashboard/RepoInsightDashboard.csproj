<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>rid</AssemblyName>
    <RootNamespace>RepoInsightDashboard</RootNamespace>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>rid</ToolCommandName>
    <PackageId>RepoInsightDashboard</PackageId>
    <Version>1.0.0</Version>
    <Description>Repo Insight Dashboard — 程式碼庫語義分析 CLI 工具</Description>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <Optimize>true</Optimize>
    <!-- Suppress nullable warnings for generated content -->
    <NoWarn>$(NoWarn);CS8600;CS8602;CS8603</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="LibGit2Sharp" Version="0.31.0" />
    <PackageReference Include="Microsoft.OpenApi.Readers" Version="1.6.22" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
    <PackageReference Include="YamlDotNet" Version="16.3.0" />
  </ItemGroup>

</Project>
